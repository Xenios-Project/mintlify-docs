{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xenios Trading API",
  "description": "Place and manage orders, stream live market and account data, and read wallets, deposits and reference data over one authenticated gateway.",
  "colors": {
    "primary": "#0F8B7E",
    "light": "#4FE3D0",
    "dark": "#0A6F64"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "guides/authentication",
              "guides/environments",
              "guides/responses",
              "guides/errors"
            ]
          },
          {
            "group": "Trading",
            "icon": "arrow-right-arrow-left",
            "pages": [
              "guides/orders",
              "guides/idempotency",
              "guides/fees-and-limits"
            ]
          },
          {
            "group": "Market Data",
            "icon": "chart-candlestick",
            "pages": ["guides/market-data"]
          },
          {
            "group": "Wallets & Deposits",
            "icon": "wallet",
            "pages": ["guides/wallets-deposits"]
          },
          {
            "group": "Realtime",
            "icon": "bolt",
            "pages": ["guides/websockets"]
          },
          {
            "group": "Operations",
            "icon": "shield-halved",
            "pages": [
              "guides/security",
              "guides/rate-limits",
              "guides/pagination"
            ]
          },
          {
            "group": "Architecture",
            "icon": "sitemap",
            "pages": ["architecture/event-plane"]
          },
          {
            "group": "Resources",
            "icon": "book-open",
            "pages": ["guides/concepts", "guides/faq", "changelog"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ]
  },
  "logo": {
    "light": "/logo/logo.webp",
    "dark": "/logo/logo.webp"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@xeniosproject.com"
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "seo": {
    "metatags": {
      "og:title": "Xenios Trading API",
      "og:description": "One authenticated gateway for orders, market data, wallets and realtime streams.",
      "og:type": "website"
    },
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "website": "https://xeniosproject.com"
    }
  }
}
